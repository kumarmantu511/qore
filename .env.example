# QoreChain Auto Bot - Environment Configuration
# Bu dosyayı kendi değerlerinizle düzenleyin

# Browser Settings
# Local debug icin false, Render icin true
BROWSER_HEADLESS=false
BROWSER_SLOW_MO=100
BROWSER_VIEWPORT_WIDTH=1920
BROWSER_VIEWPORT_HEIGHT=1080

# Account Creation
ACCOUNT_EMAIL_PREFIX=qoreuser
ACCOUNT_PASSWORD_LENGTH=12

# Email Domains (comma-separated)
EMAIL_DOMAINS=gmail.com,yahoo.com,outlook.com,protonmail.com,icloud.com,mail.com

# Timing & Retry
TIMING_PAGE_TIMEOUT=60000
TIMING_MAX_RETRIES=3
TIMING_MULTI_ACCOUNT_DELAY=5000
TIMING_MULTI_ACCOUNT_COUNT=3

# Dashboard
DASHBOARD_REFRESH_INTERVAL=30000
DASHBOARD_PORT=3000

# URLs
URL_DASHBOARD=https://dashboard.qorechain.io/
URL_LOGIN=https://auth.qorechain.io/login?response_type=code&client_id=2jfd4cromgb1skmd2cio68tf6d&redirect_uri=https%3A%2F%2Fdashboard.qorechain.io%2Fapi%2Fauth%2Fcallback&scope=openid+profile+email+aws.cognito.signin.user.admin&state=PtD9iqpR8XDkCQD1FnSM1w&code_challenge=5JCb09VD3WNfMSkWLosdTbKroWUR2BFE-z7-JOvJ6DM&code_challenge_method=S256
URL_SIGNUP=https://auth.qorechain.io/signup?response_type=code&client_id=2jfd4cromgb1skmd2cio68tf6d&redirect_uri=https%3A%2F%2Fdashboard.qorechain.io%2Fapi%2Fauth%2Fcallback&scope=openid+profile+email+aws.cognito.signin.user.admin&state=PtD9iqpR8XDkCQD1FnSM1w&code_challenge=5JCb09VD3WNfMSkWLosdTbKroWUR2BFE-z7-JOvJ6DM&code_challenge_method=S256

# Storage
STORAGE_BASE_DIR=.
STORAGE_WALLETS_FILE=data/wallets.json
STORAGE_SCREENSHOTS_DIR=screenshots

# Token Transfer (Wallet Address to send tokens)
# Add your wallet address here to receive tokens from created accounts
TRANSFER_WALLET_ADDRESS=

# Render
# Render worker uzerinde genelde su degerler kullanilir:
# RENDER=true
# BROWSER_HEADLESS=true
# BROWSER_SLOW_MO=0
# STORAGE_BASE_DIR=/var/data/qorechain-bot
# TIMING_MULTI_ACCOUNT_COUNT=0
